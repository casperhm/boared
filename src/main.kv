#:kivy 2.3.1
#:import dp kivy.metrics.dp
    
<RangeSlider>:
    size_hint_y: None
    size_hint_x: 1
    height: "65dp"

    # Define the first slider
    MDSlider:
        id: slider_min
        size_hint_x: 1
        min: 0
        max: 0
        value: 0
        hint: True
        pos_hint: {"center_y": .5}
        step: 1
        thumb_color_inactive: 0, 1, 0, 1
        thumb_color_active: 0, 1, 0, 1
        show_off: False
        elevation: 0
        ripple_scale: 0
        hint: False

    # Define the second slider
    MDSlider:
        id: slider_max
        size_hint_x: 1
        min: 0
        max: 0
        value: 0
        hint: True
        pos_hint: {"center_y": .5}
        step: 1
        track_color_active: 0.5, 0.5, 0.5, 1
        track_color_inactive: 0.5, 0.5, 0.5, 1
        color: 0.5, 0.5, 0.5, 1
        thumb_color_inactive: 0, 1, 0, 1
        thumb_color_active: 0, 1, 0, 1
        elevation: 0
        ripple_scale: 0
        hint: False
